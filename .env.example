# Copy to .env.local and fill in values from your Supabase project
# Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only — never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Shared secret for Apple Health / Health Auto Export webhook
# Generate any random 40+ char string
HEALTH_WEBHOOK_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
